{
  "private String": { "prefix": "prs", "body": ["private String ${1:name};"] },
  "private Long": { "prefix": "prl", "body": ["private Long ${1:name};"] },
  "private Integer": { "prefix": "pri", "body": ["private Integer ${1:name};"] },
  "private Double": { "prefix": "prd", "body": ["private Double ${1:name};"] },
  "private BigDecimal": { "prefix": "prbd", "body": ["private BigDecimal ${1:name};"] },
  "private LocalDate": { "prefix": "prld", "body": ["private LocalDate ${1:name};"] },
  "private LocalDateTime": { "prefix": "prldt", "body": ["private LocalDateTime ${1:name};"] },

  "private final <Type>": { "prefix": "pf", "body": ["private final ${1:Type} ${2:name};"] },
  "private final String": { "prefix": "pfs", "body": ["private final String ${1:name};"] },
  "private final int": { "prefix": "pfi", "body": ["private final int ${1:name};"] },
  "private final Long": { "prefix": "pfL", "body": ["private final Long ${1:name};"] },
  "private final Integer": { "prefix": "pfI", "body": ["private final Integer ${1:name};"] },
  "private final Double": { "prefix": "pfD", "body": ["private final Double ${1:name};"] },
  "private final BigDecimal": { "prefix": "pfBd", "body": ["private final BigDecimal ${1:name};"] },
  "private final LocalDate": { "prefix": "pfld", "body": ["private final LocalDate ${1:name};"] },
  "private final LocalDateTime": { "prefix": "pfldt", "body": ["private final LocalDateTime ${1:name};"] },

  "private static final <Type>": { "prefix": "psft", "body": ["private static final ${1:Type} ${2:NAME} = ${3};"] },
  "private static final String": { "prefix": "psfs", "body": ["private static final String ${1:NAME} = \"$2\";"] },
  "private static final int": { "prefix": "psfi", "body": ["private static final int ${1:NAME} = ${2:0};"] },
  "private static final long": { "prefix": "psfl", "body": ["private static final long ${1:NAME} = ${2:0}L;"] },
  "private static final boolean": { "prefix": "psfb", "body": ["private static final boolean ${1:NAME} = ${2:false};"] },
  "private static final Long": { "prefix": "psfL", "body": ["private static final Long ${1:NAME} = ${2}L;"] },
  "private static final Integer": { "prefix": "psfI", "body": ["private static final Integer ${1:NAME} = ${2:0};"] },
  "private static final Double": { "prefix": "psfD", "body": ["private static final Double ${1:NAME} = ${2};"] },
  "private static final Boolean": { "prefix": "psfB", "body": ["private static final Boolean ${1:NAME} = ${2:Boolean.FALSE};"] },
  "private static final BigDecimal": { "prefix": "psfBd", "body": ["private static final BigDecimal ${1:NAME} = ${2:BigDecimal.ZERO};"] },
  "private static final LocalDate": { "prefix": "psfld", "body": ["private static final LocalDate ${1:NAME} = ${2};"] },
  "private static final LocalDateTime": { "prefix": "psfldt", "body": ["private static final LocalDateTime ${1:NAME} = ${2};"] },

  "public static final <Type>": { "prefix": "psf", "body": ["public static final ${1:Type} ${2:NAME} = ${3};"] },
  "public static final String": { "prefix": "Psfs", "body": ["public static final String ${1:NAME} = \"$2\";"] },
  "public static final int": { "prefix": "Psfi", "body": ["public static final int ${1:NAME} = ${2:0};"] },
  "public static final long": { "prefix": "Psfl", "body": ["public static final long ${1:NAME} = ${2:0}L;"] },
  "public static final boolean": { "prefix": "Psfb", "body": ["public static final boolean ${1:NAME} = ${2:false};"] },
  "public static final Long": { "prefix": "PsfL", "body": ["public static final Long ${1:NAME} = ${2}L;"] },
  "public static final Integer": { "prefix": "PsfI", "body": ["public static final Integer ${1:NAME} = ${2:0};"] },
  "public static final Double": { "prefix": "PsfD", "body": ["public static final Double ${1:NAME} = ${2};"] },
  "public static final Boolean": { "prefix": "PsfB", "body": ["public static final Boolean ${1:NAME} = ${2:Boolean.FALSE};"] },
  "public static final BigDecimal": { "prefix": "PsfBd", "body": ["public static final BigDecimal ${1:NAME} = ${2:BigDecimal.ZERO};"] },
  "public static final LocalDate": { "prefix": "Psfld", "body": ["public static final LocalDate ${1:NAME} = ${2};"] },
  "public static final LocalDateTime": { "prefix": "Psfldt", "body": ["public static final LocalDateTime ${1:NAME} = ${2};"] },

  "serialVersionUID": { "prefix": "serial", "body": ["private static final long serialVersionUID = ${1:1}L;"] },

  "indexed for loop": { "prefix": "fori", "body": ["for (int ${1:i} = 0; $1 < ${2:n}; $1++) {", "\t$0", "}"] },
  "for over list by index": { "prefix": "forl", "body": ["for (int ${1:i} = 0; $1 < ${2:list}.size(); $1++) {", "\t${3:Object} ${4:e} = $2.get($1);", "\t$0", "}"] },
  "if / else": { "prefix": "ife", "body": ["if (${1:condition}) {", "\t$2", "} else {", "\t$0", "}"] },
  "do / while": { "prefix": "dowhile", "body": ["do {", "\t$0", "} while (${1:condition});"] },
  "while iterator": { "prefix": "whileit", "body": ["while (${1:it}.hasNext()) {", "\t${2:Object} ${3:e} = $1.next();", "\t$0", "}"] },
  "instanceof": { "prefix": "inst", "body": ["${1:obj} instanceof ${2:Type}"] },
  "printStackTrace": { "prefix": "pst", "body": ["${1:e}.printStackTrace();"] },
  "println variable": { "prefix": "soutv", "body": ["System.out.println(\"${1:var} = \" + $1);$0"] },
  "anonymous Runnable": { "prefix": "runn", "body": ["new Runnable() {", "\t@Override", "\tpublic void run() {", "\t\t$0", "\t}", "}"] },
  "lazy getter": { "prefix": "lazy", "body": ["private ${1:Type} ${2:field};", "", "public $1 get${3:Field}() {", "\tif ($2 == null) {", "\t\t$2 = ${4:new $1()};", "\t}", "\treturn $2;", "}"] }
}
